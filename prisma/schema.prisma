generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FeedbackStatus {
  PENDING
  APPROVED
  REJECTED
}

model Feedback {
  id        String         @id @default(uuid())
  name      String
  message   String
  project   String?
  locale    String?
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())

  @@index([status, locale, createdAt(sort: Desc)])
}

{
  "headers": [
    {
      "source": "/(react|vite|javascript|nodejs|css|tailwind|material-ui|swiperjs|framer-motion|chartjs|next\.js|typescript|postgresql|express|mercado_pago|prisma|firebase|threejs|mongodb|dnd_kit|html|axios|styled-components|cypress)\.(png|svg|jpg)$",
